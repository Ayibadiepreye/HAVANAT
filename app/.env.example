# Copy to .env and fill in.
# Havanat Frontend — Environment Variables
# Set VITE_USE_BACKEND=true to hit the real Express + Postgres backend.
# Set to false (or leave blank) to use the localStorage mock.
VITE_USE_BACKEND=true
VITE_API_URL=http://localhost:4000

# Paystack public key (frontend-safe)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_efd6d41cf4235bda29f127f75ec1f261ffc6b116

# Cloudinary (for product images)
# Get these from https://cloudinary.com/console
# Create an unsigned upload preset at Settings → Upload → Add upload preset → Signing mode: unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
