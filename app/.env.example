# Havanat Frontend — Environment Variables
# Copy to `.env` and fill in real values.

# ─── Backend wiring ────────────────────────────────────────────────
# When true, stores call the real Express + Postgres backend.
# When false, falls back to localStorage mocks (offline mode).
VITE_USE_BACKEND=true

# Backend base URL (no trailing slash).
# In production: https://api.havanat.store
VITE_API_URL=http://localhost:4000

# ─── Paystack (public key — safe to expose) ────────────────────────
# Test key for local dev: pk_test_xxx
# Live key: pk_live_xxx (replace when going to production)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_public

# ─── Cloudinary (image uploads) ────────────────────────────────────
# Get from https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Create an unsigned upload preset at Settings → Upload → Add upload preset
VITE_CLOUDINARY_UPLOAD_PRESET=your-preset-name
# Only needed for signed uploads (we use unsigned for now)
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=
