# Havanat Backend — Environment Variables
# Copy this file to `.env` and fill in real values for production.
# For local development, use the test keys below.

NODE_ENV=development
PORT=4000

# ─── Database (Neon Postgres) ─────────────────────────────────────
# Get from https://console.neon.tech → your project → Connection string
# Must end with ?sslmode=require for Neon.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ─── JWT ───────────────────────────────────────────────────────────
# Generate strong random strings:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-random-48-byte-hex
JWT_REFRESH_SECRET=replace-with-different-random-48-byte-hex
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ─── CORS ──────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3002

# ─── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ─── Email (Resend) ────────────────────────────────────────────────
# Get from https://resend.com/api-keys
# Domain must be verified at https://resend.com/domains before you can send from it.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Havanat <concierge@havanat.store>
EMAIL_REPLY_TO=concierge@havanat.store

# ─── Paystack ──────────────────────────────────────────────────────
# Test keys (use for local dev): https://dashboard.paystack.com/#/settings/developers
# Live keys: replace when going to production
PAYSTACK_SECRET_KEY=sk_test_your_paystack_test_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_public

# ─── Google OAuth (optional) ───────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ─── Frontend URL (for emails + redirects) ─────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
