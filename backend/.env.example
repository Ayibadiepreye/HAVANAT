# Havanat Backend — Environment Variables
#
# Copy this file to `.env` and fill in the values. The backend will warn on
# startup if any required variable is missing.

# ──────────────────── Core ────────────────────
NODE_ENV=development
PORT=4000

# ──────────────────── Database ────────────────────
# Neon Postgres (free tier works). Get from https://console.neon.tech
DATABASE_URL=postgres://user:pass@ep-xxxx.neon.tech/havanat?sslmode=require

# ──────────────────── JWT ────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ──────────────────── CORS ────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ──────────────────── Rate limiting ────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ──────────────────── Object storage (S3 / R2 / Cloudinary) ────────────────────
# S3_BUCKET=havanat-prod-images
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE=https://cdn.havanat.store

# ──────────────────── Email — Resend ────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_CX9PckrR_DWv1WrJCRPyUJ38676iZcusn
EMAIL_FROM=Havanat <concierge@havanat.store>
EMAIL_REPLY_TO=concierge@havanat.store

# ──────────────────── Payments — Paystack ────────────────────
# Get from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_b1307f368587fd0b030fea3915072fe9fdfabdf5
PAYSTACK_PUBLIC_KEY=pk_test_efd6d41cf4235bda29f127f75ec1f261ffc6b116
PAYSTACK_WEBHOOK_SECRET=
# Live keys (when you switch from test to production):
#   sk_live_xxx
#   pk_live_xxx

# ──────────────────── Google OAuth ────────────────────
# Set these up at https://console.cloud.google.com/apis/credentials
# 1. Create a project (or select existing)
# 2. Configure consent screen (External, app name "Havanat", support email, scopes: email, profile, openid)
# 3. Create OAuth client ID → Application type: Web application
# 4. Authorized JavaScript origins:
#      - http://localhost:3000
#      - https://www.havanat.store
#      - https://havanat.store
# 5. Authorized redirect URIs:
#      - http://localhost:4000/api/auth/google/callback
#      - https://api.havanat.store/api/auth/google/callback
# 6. Copy the Client ID and Client Secret below
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ──────────────────── Frontend URL ────────────────────
# Used in email links + Paystack callback URLs
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://www.havanat.store
